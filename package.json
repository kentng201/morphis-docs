{
    "name": "@morphis/docs",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Official documentation site for Morphis built with Nextra.",
    "scripts": {
        "dev": "next dev --turbopack",
        "build": "next build",
        "postbuild": "pagefind --site .next/server/app --output-path public/_pagefind",
        "start": "next start",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "next": "^15.5.4",
        "react": "^19.1.1",
        "react-dom": "^19.1.1",
        "nextra": "^4.6.1",
        "nextra-theme-docs": "^4.6.1"
    },
    "devDependencies": {
        "@types/node": "^24.7.2",
        "@types/react": "^19.1.17",
        "@types/react-dom": "^19.1.9",
        "pagefind": "^1.5.2",
        "typescript": "^5.9.3"
    },
    "keywords": [
        "morphis",
        "docs",
        "nextra",
        "nextjs"
    ],
    "license": "MIT"
}